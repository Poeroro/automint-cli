# ─── WAJIB: Private Key ───
# Buat wallet khusus AutoMint. Jangan pake wallet utama.
# Single wallet:
PRIVATE_KEY=YOUR_PRIVATE_KEY

# ─── OPSIONAL: OpenSea API Key ───
# Tanpa key: 16 req/window (cukup untuk normal use).
# Kalo kena error "API HTTP 401" atau "429", daftar gratis di:
# https://docs.opensea.io/reference/api-keys
# OPENSEA_API_KEY=your_key_here
# Multi-account (pisah koma):
# PRIVATE_KEYS=0xabc...,0xdef...,0x123...

# ─── OPSIONAL: Custom RPC per Chain ───
# Biarkan kosong untuk memakai RPC default.
# RPC_ETH=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_OP=https://optimism-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_ARB=https://arbitrum-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BSC=https://bsc-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── OPSIONAL: Gas Guard ───
# Abort mint jika gas price melebihi batas ini. Lindungi dari mint di gas 200+ Gwei.
# MAX_GAS_GWEI=50

# ─── OPSIONAL: Merkle Proof untuk Allowlist ───
# Isi kalo contract pakai Merkle tree dan API otomatis gagal fetch proof.
# Format: bytes32 hex pisah koma.
# MERKLE_PROOF=0xabc...,0xdef...

# ─── OPSIONAL: Notifikasi Telegram ───
# Buat bot via @BotFather, ambil token + chat_id.
# TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxx
# TELEGRAM_CHAT_ID=123456789

# ─── OPSIONAL: Notifikasi Discord ───
# Server Settings → Integrations → Webhooks → Copy URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
