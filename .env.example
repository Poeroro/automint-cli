# ─── WAJIB: Private Key ───
# Buat wallet khusus AutoMint. Jangan pake wallet utama.
# Single wallet:
PRIVATE_KEY=YOUR_PRIVATE_KEY
# Multi-account (pisah koma):
# PRIVATE_KEYS=0xabc...,0xdef...,0x123...

# ─── WAJIB: OpenSea API Key ───
# Daftar gratis di https://opensea.io/account/api
# OPENSEA API key diperlukan untuk resolve contract dari URL OpenSea.
# Alternatif: pake --contract langsung (gak butuh OS API key)
OPENSEA_API_KEY=YOUR_API_KEY

# ─── OPSIONAL: Custom RPC per Chain ───
# Biarkan kosong untuk memakai RPC default (Flashbots untuk ETH, publik untuk lainnya).
# Format: RPC_CHAINNAME=https://...
# RPC_ETH=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_OP=https://optimism-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_ARB=https://arbitrum-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BSC=https://bsc-mainnet.g.alchemy.com/v2/YOUR_KEY
